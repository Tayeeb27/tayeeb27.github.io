---
import site from '../data/site.json';
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-content px-6 py-20 sm:px-8 lg:py-28">
    <div class="grid items-center gap-14 lg:grid-cols-[1fr_260px] lg:gap-16">
      <div>
        <div class="status-badge mb-6">
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-success" aria-hidden="true"></span>
          {site.status}
        </div>

        <p class="section-label">{site.role}</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          {site.name}
        </h1>

        <div class="terminal-block mt-8 max-w-xl">
          <p>
            <span class="text-accent">const</span> engineer = {'{'}
          </p>
          <p class="pl-4">
            role: <span class="text-foreground">"{site.role}"</span>,
          </p>
          <p class="pl-4">
            focus: <span class="text-foreground">"APIs → UI → deploy"</span>,
          </p>
          <p class="pl-4">
            location: <span class="text-foreground">"{site.location}"</span>
          </p>
          <p>{'};'}</p>
        </div>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          {site.tagline}
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          {site.stack.map((tech) => (
            <span class="tech-tag tech-tag-active">{tech}</span>
          ))}
        </div>

        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/experience" class="btn-primary">View experience</a>
          <a href="/projects" class="btn-secondary">View projects</a>
          <a href={site.cvUrl} download={site.cvFilename} class="btn-secondary">Download CV</a>
          <a href={site.github} target="_blank" rel="noopener noreferrer" class="btn-secondary">GitHub</a>
          <a href="/contact" class="btn-secondary">Get in touch</a>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-[260px] lg:mx-0">
        <div class="absolute -inset-3 rounded-image bg-gradient-to-br from-accent/20 to-transparent blur-2xl" aria-hidden="true"></div>
        <div class="relative overflow-hidden rounded-image border border-border-bright shadow-[0_0_40px_-8px_rgb(34_211_238_/_0.25)]">
          <div class="flex items-center gap-2 border-b border-border bg-surface-elevated px-3 py-2">
            <span class="h-2.5 w-2.5 rounded-full bg-red-500/80" aria-hidden="true"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/80" aria-hidden="true"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-green-500/80" aria-hidden="true"></span>
            <span class="ml-2 font-mono text-[10px] text-muted">profile.tsx</span>
          </div>
          <img
            src={site.photo}
            alt={`Portrait of ${site.name}`}
            class="aspect-[3/4] w-full object-cover"
            loading="eager"
            decoding="async"
            width="260"
            height="347"
          />
        </div>
      </div>
    </div>
  </div>
</section>
