---
import experience from '../data/experience.json';
import { linkCompanies } from '../utils/linkCompanies';

interface WorkItem {
  id: string;
  date: string;
  title: string;
  role: string;
  description: string;
  url?: string;
  highlights?: string[];
  current?: boolean;
}

const work = experience.work as WorkItem[];
const [featured, ...rest] = work;

const stats = [
  { value: '2+', label: 'Years commercial' },
  { value: '50k+', label: 'Monthly users shipped' },
  { value: '4', label: 'Companies & clients' },
];

function getInitials(title: string): string {
  const words = title.replace(/[^a-zA-Z\s]/g, '').trim().split(/\s+/);
  if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
  return title.slice(0, 2).replace(/[^a-zA-Z]/g, '').toUpperCase() || title.slice(0, 1).toUpperCase();
}
---

<section class="border-t border-border bg-surface/30 py-20">
  <div class="mx-auto max-w-content px-6 sm:px-8">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="section-label">// work_history</p>
        <h2 class="section-heading mt-2">Work experience</h2>
        <p class="section-subheading">
          Commercial roles across B2B SaaS, consumer platforms, and contract delivery.
        </p>
      </div>
      <a href="/experience" class="hidden shrink-0 font-mono text-xs text-accent transition hover:text-cyan-300 sm:block">
        view_all() →
      </a>
    </div>

    <div class="mt-10 grid gap-3 sm:grid-cols-3">
      {stats.map((stat) => (
        <div class="surface-card px-5 py-4 text-center sm:text-left">
          <p class="font-mono text-2xl font-semibold text-accent">{stat.value}</p>
          <p class="mt-1 text-sm text-muted">{stat.label}</p>
        </div>
      ))}
    </div>

    <article class="group relative mt-10 overflow-hidden rounded-card border border-accent/30 bg-surface shadow-[0_0_40px_-8px_rgb(34_211_238_/_0.2)] transition hover:border-accent/50">
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-accent/10 via-transparent to-transparent" aria-hidden="true"></div>
      <div class="relative grid gap-8 p-6 sm:p-8 lg:grid-cols-[auto_1fr] lg:items-start">
        <div class="flex items-start gap-4 lg:flex-col lg:items-center lg:text-center">
          <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-card border border-accent/40 bg-accent/10 font-mono text-xl font-bold text-accent">
            {getInitials(featured.title)}
          </div>
          <div class="lg:mt-2">
            {featured.current && (
              <span class="status-badge mb-2">Current role</span>
            )}
            <time class="block font-mono text-xs text-muted">{featured.date}</time>
          </div>
        </div>

        <div>
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="font-mono text-xs text-accent">{featured.role}</p>
              <h3 class="mt-1 text-2xl font-semibold text-foreground">
                {featured.url ? (
                  <a href={featured.url} target="_blank" rel="noopener noreferrer" class="transition hover:text-accent">
                    {featured.title}
                  </a>
                ) : (
                  featured.title
                )}
              </h3>
            </div>
            {featured.url && (
              <a
                href={featured.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden rounded-lg border border-border bg-surface-elevated px-3 py-1.5 font-mono text-xs text-muted transition hover:border-accent hover:text-accent sm:inline-flex"
                aria-label={`Visit ${featured.title}`}
              >
                visit_site() ↗
              </a>
            )}
          </div>

          <ul class="mt-5 space-y-2.5">
            {(featured.highlights ?? []).map((highlight) => (
              <li class="flex gap-3 text-sm leading-relaxed text-muted">
                <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <span set:html={linkCompanies(highlight)} />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </article>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((item, index) => (
        <article class="group surface-card-glow flex flex-col p-5 hover:-translate-y-0.5">
          <div class="flex items-start justify-between gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-border bg-surface-elevated font-mono text-xs font-bold text-accent transition group-hover:border-accent/40 group-hover:bg-accent/10">
              {getInitials(item.title)}
            </div>
            <span class="font-mono text-[10px] text-muted">0{index + 2}</span>
          </div>

          <time class="mt-4 block font-mono text-[11px] text-muted">{item.date}</time>
          <p class="mt-1 font-mono text-xs text-accent">{item.role}</p>
          <h3 class="mt-1 text-lg font-semibold text-foreground">
            {item.url ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="transition hover:text-accent">
                {item.title}
              </a>
            ) : (
              item.title
            )}
          </h3>

          <ul class="mt-4 flex-1 space-y-2">
            {(item.highlights ?? []).slice(0, 2).map((highlight) => (
              <li class="flex gap-2 text-sm leading-snug text-muted">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-border-bright" aria-hidden="true"></span>
                <span set:html={linkCompanies(highlight)} />
              </li>
            ))}
          </ul>

          {item.url && (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 font-mono text-[11px] text-accent opacity-0 transition group-hover:opacity-100 hover:text-cyan-300"
            >
              visit_site() ↗
            </a>
          )}
        </article>
      ))}
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <p class="text-center text-sm text-muted sm:text-left">
        Education, certifications, and the full career timeline on the experience page.
      </p>
      <a href="/experience" class="btn-secondary shrink-0 font-mono text-xs">View full timeline →</a>
    </div>
  </div>
</section>
