---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectFilter from '../../components/ProjectFilter';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const projectItems = sorted.map((project) => ({
  id: project.id,
  title: project.data.title,
  subtitle: project.data.subtitle,
  summary: project.data.summary,
  tech: project.data.tech,
  image: project.data.images[0],
  imageAlt: project.data.imageAlt,
}));
---

<BaseLayout title="Projects" description="Portfolio projects by Tayeeb Islam">
  <section class="page-header">
    <div class="mx-auto max-w-content px-6 py-12 sm:px-8">
      <p class="section-label">// projects</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Project archive</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        Personal full stack builds — filter by technology. Company and client work not included.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-content px-6 py-16 sm:px-8 lg:py-20">
    <ProjectFilter client:load projects={projectItems} />
  </section>
</BaseLayout>
