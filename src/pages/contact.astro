---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import site from '../data/site.json';
---

<BaseLayout title="Contact" description={`Contact ${site.name}`}>
  <section class="page-header">
    <div class="mx-auto max-w-content px-6 py-12 sm:px-8">
      <p class="section-label">// contact</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Get in touch</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        Send a message or reach out directly — I typically respond within 24 hours.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-content px-6 py-16 sm:px-8 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-2">
      <ContactForm />

      <div class="space-y-4">
        <div class="surface-card p-6">
          <h3 class="font-mono text-xs text-accent">location</h3>
          <p class="mt-2 text-foreground">{site.location}</p>
        </div>
        <div class="surface-card p-6">
          <h3 class="font-mono text-xs text-accent">phone</h3>
          <p class="mt-2">
            <a href={`tel:${site.phone}`} class="text-foreground transition hover:text-accent">
              07516 287962
            </a>
          </p>
        </div>
        <div class="surface-card p-6">
          <h3 class="font-mono text-xs text-accent">email</h3>
          <p class="mt-2">
            <a href={`mailto:${site.email}`} class="text-foreground transition hover:text-accent">
              {site.email}
            </a>
          </p>
        </div>
        <div class="surface-card p-6">
          <h3 class="font-mono text-xs text-accent">links</h3>
          <div class="mt-3 flex gap-4">
            <a href={site.github} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-accent hover:text-cyan-300">
              GitHub
            </a>
            <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-accent hover:text-cyan-300">
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
